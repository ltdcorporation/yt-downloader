[Unit]
Description=YT Downloader API
After=network.target redis.service postgresql.service

[Service]
Type=simple
User=local-lenovo
WorkingDirectory=/home/local-lenovo/yt-downloader/apps/backend
EnvironmentFile=/home/local-lenovo/yt-downloader/apps/backend/.env
ExecStart=/usr/bin/env go run ./cmd/api
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
