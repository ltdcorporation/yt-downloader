[Unit]
Description=YT Downloader Web (Next.js)
After=network.target

[Service]
Type=simple
User=local-lenovo
WorkingDirectory=/home/local-lenovo/yt-downloader/apps/web
EnvironmentFile=/home/local-lenovo/yt-downloader/apps/web/.env
ExecStart=/usr/bin/env npm run start
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
