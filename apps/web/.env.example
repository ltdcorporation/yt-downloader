# Client-side API base (browser). Use internal Next.js proxy by default.
NEXT_PUBLIC_API_URL=/api

# Server-side upstream for proxy route + admin page fetches.
API_BASE_URL=http://127.0.0.1:8080

# Legacy fallback used by /admin page (optional)
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8080

ADMIN_BASIC_AUTH_USER=admin
ADMIN_BASIC_AUTH_PASS=change-me
