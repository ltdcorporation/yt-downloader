APP_ENV=development
HTTP_PORT=8080
HTTP_ADDR=

RATE_LIMIT_RPS=3
MAX_VIDEO_DURATION_MINUTES=60
MAX_FILE_SIZE_BYTES=1073741824
YOUTUBE_MAX_QUALITY=1080
X_MAX_QUALITY=1080
X_COOKIES_DIR=
X_COOKIES_FILES=
X_RESOLVE_TRY_WITHOUT_COOKIES=true
IG_MAX_QUALITY=1080
IG_COOKIES_DIR=
IG_COOKIES_FILES=
IG_RESOLVE_TRY_WITHOUT_COOKIES=true
TT_MAX_QUALITY=1080
TT_COOKIES_DIR=
TT_COOKIES_FILES=
TT_RESOLVE_TRY_WITHOUT_COOKIES=true

MP3_BITRATE=128
MP3_OUTPUT_TTL_MINUTES=60
VIDEO_CUT_OUTPUT_TTL_MINUTES=60
VIDEO_CUT_MAX_DURATION_SEC=180
VIDEO_CUT_FFMPEG_BINARY=ffmpeg
YTD_HEATMAP_TRIM_ENABLED=true
JOB_RETENTION_DAYS=14

REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
POSTGRES_DSN=postgres://postgres:postgres@127.0.0.1:5432/ytd?sslmode=disable

ADMIN_BASIC_AUTH_USER=admin
ADMIN_BASIC_AUTH_PASS=change-me

AUTH_SESSION_COOKIE_NAME=qs_session
AUTH_SESSION_COOKIE_DOMAIN=
AUTH_SESSION_COOKIE_SECURE=false
AUTH_SESSION_TTL_HOURS=24
AUTH_REMEMBER_SESSION_TTL_HOURS=720
AUTH_BCRYPT_COST=12

# Google OAuth (accepts comma-separated client IDs, or use single GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_IDS=
GOOGLE_CLIENT_ID=

R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_REGION=auto
R2_BUCKET=ytd-temp
R2_KEY_PREFIX=yt-downloader/prod
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

AVATAR_PUBLIC_BASE_URL=https://avatar.indobang.site
AVATAR_R2_KEY_PREFIX=yt-downloader/prod/avatars
AVATAR_UPLOAD_MAX_BYTES=2097152
AVATAR_FFMPEG_BINARY=ffmpeg

YTDLP_BINARY=yt-dlp
YTDLP_JS_RUNTIMES=node

CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
