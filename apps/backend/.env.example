APP_ENV=development
HTTP_PORT=8080

RATE_LIMIT_RPS=3
MAX_VIDEO_DURATION_MINUTES=60
MAX_FILE_SIZE_BYTES=1073741824
YOUTUBE_MAX_QUALITY=1080

MP3_BITRATE=128
MP3_OUTPUT_TTL_MINUTES=60
JOB_RETENTION_DAYS=14

REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
POSTGRES_DSN=postgres://postgres:postgres@127.0.0.1:5432/ytd?sslmode=disable

ADMIN_BASIC_AUTH_USER=admin
ADMIN_BASIC_AUTH_PASS=change-me

R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_BUCKET=ytd-temp
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

YTDLP_BINARY=/usr/local/bin/yt-dlp
YTDLP_JS_RUNTIMES=node
